---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;

const notice = Astro.url.searchParams.get("notice");
const noticeMessage = notice === "password_updated" ? "Hasło zostało zmienione." : null;
---

<Layout title="Panel">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      {
        noticeMessage && (
          <p class="mb-4 rounded-lg border border-emerald-500/30 bg-emerald-900/30 px-3 py-2 text-sm text-emerald-300">
            {noticeMessage}
          </p>
        )
      }
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Panel
      </h1>
      <p class="text-blue-100/80">
        Witaj, <span class="font-semibold text-white">{user?.email}</span>
      </p>
      <p class="mt-2 text-sm text-blue-100/50">Ta strona jest dostępna tylko dla zalogowanych.</p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Wyloguj się
        </button>
      </form>
    </div>
  </div>
</Layout>
