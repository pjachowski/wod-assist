---
import Layout from "@/layouts/Layout.astro";
import UpdatePasswordForm from "@/components/auth/UpdatePasswordForm";
import { authErrorMessage } from "@/lib/auth-errors";
import { PASSWORD_RECOVERY_COOKIE } from "@/lib/supabase";

// Deliberately NOT in middleware's PROTECTED_ROUTES: that list redirects to /auth/signin,
// while a failed recovery context must land on /auth/forgot-password with a message
// and a resend form. The guard requires an active session AND the recovery-intent
// marker at the same time — a regular signed-in session is not enough.
const hasRecoveryIntent = Astro.cookies.get(PASSWORD_RECOVERY_COOKIE)?.value === "1";
if (!Astro.locals.user || !hasRecoveryIntent) {
  return Astro.redirect("/auth/forgot-password?error=otp_expired");
}

const error = authErrorMessage(Astro.url.searchParams.get("error"));
---

<Layout title="Nowe hasło">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Ustaw nowe hasło
      </h1>
      <UpdatePasswordForm serverError={error} client:load />
    </div>
  </div>
</Layout>
